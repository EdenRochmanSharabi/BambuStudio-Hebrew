msgstr "כיצד להתקין"

msgid "Upgrade"
msgstr "שדרג"

msgid "Current firmware does not support file transfer to internal storage."
msgstr "הקושחה הנוכחית אינה תומכת בהעברת קבצים לאחסון פנימי."

msgid "Send to Printer storage"
msgstr "שלח לאחסון המדפסת"

msgid "Try to connect"
msgstr "נסה להתחבר"

msgid "Internal Storage"
msgstr "אחסון פנימי"

msgid "External Storage"
msgstr "אחסון חיצוני"

msgid "Upload file timeout, please check if the firmware version supports it."
msgstr "העלאת קובץ חרגה מזמן, אנא בדוק אם גרסת הקושחה תומכת בכך."

msgid "Connection timed out, please check your network."
msgstr "החיבור חרג מזמן, אנא בדוק את הרשת שלך."

msgid "Connection failed. Click the icon to retry"
msgstr "החיבור נכשל. לחץ על הסמל לניסיון חוזר"

msgid "Cannot send the print task when the upgrade is in progress"
msgstr "לא ניתן לשלוח משימת הדפסה כאשר השדרוג מתבצע"

msgid "The selected printer is incompatible with the chosen printer presets."
msgstr "המדפסת שנבחרה אינה תואמת לפרופילי המדפסת שנבחרו."

msgid "Storage needs to be inserted before send to printer."
msgstr "יש להכניס אחסון לפני שליחה למדפסת."

msgid "The printer is required to be in the same LAN as Bambu Studio."
msgstr "המדפסת נדרשת להיות באותה רשת מקומית כמו Bambu Studio."

msgid "The printer does not support sending to printer storage."
msgstr "המדפסת אינה תומכת בשליחה לאחסון המדפסת."

msgid "Sending..."
msgstr "שולח..."

msgid "File upload timed out. Please check if the firmware version supports this operation or verify if the printer is functioning properly."
msgstr "העלאת הקובץ חרגה מזמן. אנא בדוק אם גרסת הקושחה תומכת בפעולה זו או וודא שהמדפסת פועלת כראוי."

msgid "Sending failed, please try again!"
msgstr "השליחה נכשלה, אנא נסה שוב!"

msgid "Helio action completed successfully."
msgstr "פעולת Helio הושלמה בהצלחה."

msgid "Slice ok."
msgstr "החיתוך הצליח."

msgid "View all Daily tips"
msgstr "הצג את כל הטיפים היומיים"

msgid "Failed to create socket"
msgstr "יצירת שקע נכשלה"

msgid "Failed to connect socket"
msgstr "חיבור שקע נכשל"

msgid "Failed to publish login request"
msgstr "פרסום בקשת התחברות נכשל"

msgid "Get ticket from device timeout"
msgstr "קבלת כרטיס מההתקן חרגה מזמן"

msgid "Get ticket from server timeout"
msgstr "קבלת כרטיס מהשרת חרגה מזמן"

