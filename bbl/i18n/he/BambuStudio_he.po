msgid "The filament may not be compatible with the current machine settings. Generic filament presets will be used."
msgstr "ייתכן שהפילמנט אינו תואם להגדרות המכונה הנוכחיות. ייעשה שימוש בהגדרות פילמנט גנריות."

msgid "The filament model is unknown. Still using the previous filament preset."
msgstr "דגם הפילמנט אינו ידוע. עדיין משתמש בהגדרות הפילמנט הקודמות."

msgid "The filament model is unknown. Generic filament presets will be used."
msgstr "דגם הפילמנט אינו ידוע. ייעשה שימוש בהגדרות פילמנט גנריות."

msgid "The filament may not be compatible with the current machine settings. A random filament preset will be used."
msgstr "ייתכן שהפילמנט אינו תואם להגדרות המכונה הנוכחיות. ייעשה שימוש בהגדרות פילמנט אקראיות."

msgid "The filament model is unknown. A random filament preset will be used."
msgstr "דגם הפילמנט אינו ידוע. ייעשה שימוש בהגדרות פילמנט אקראיות."

msgid "right"
msgstr "ימין"

msgid "left"
msgstr "שמאל"

msgid "right extruder"
msgstr "מכבש ימני"

msgid "left extruder"
msgstr "מכבש שמאלי"

msgid "extruder"
msgstr "מכבש"

msgid "TPU is not supported by AMS."
msgstr "TPU אינו נתמך על ידי AMS."

msgid "AMS does not support 'Bambu Lab PET-CF'."
msgstr "AMS אינו תומך ב-'Bambu Lab PET-CF'."

msgid "The current filament doesn't support the E3D high-flow nozzle and can't be used."
msgstr "הפילמנט הנוכחי אינו תומך בזרבובית זרימה גבוהה של E3D ולא ניתן להשתמש בו."

#, possible-c-format, possible-boost-format
msgid "When using %s on the right extruder, it can only be used as support material."
msgstr "בעת שימוש ב-%s על המכבש הימני, ניתן להשתמש בו רק כחומר תמיכה."

msgid "The current filament doesn't support the TPU high-flow nozzle and can't be used."
msgstr "הפילמנט הנוכחי אינו תומך בזרבובית זרימה גבוהה של TPU ולא ניתן להשתמש בו."

msgid "Auto dynamic flow calibration is not supported for TPU filament."
msgstr "כיול זרימה דינמי אוטומטי אינו נתמך עבור פילמנט TPU."

msgid "Dynamic flow calibration is not supported for TPU 85A filament."
msgstr "כיול זרימה דינמי אינו נתמך עבור פילמנט TPU 85A."

msgid "How to feed TPU filament."
msgstr "כיצד להזין פילמנט TPU."

msgid "Using non-bambu filament may have printing quality issues."
msgstr "שימוש בפילמנט שאינו של Bambu עלול לגרום לבעיות באיכות ההדפסה."

msgid "Please cold pull before printing TPU to avoid clogging. You may use cold pull maintenance on the printer."
msgstr "יש לבצע משיכה קרה לפני הדפסת TPU כדי למנוע סתימה. ניתן להשתמש בתחזוקת משיכה קרה במדפסת."

msgid "Damp PVA will become flexible and get stuck inside AMS,please take care to dry it before use."
msgstr "PVA לח יהפוך לגמיש ויתקע בתוך ה-AMS, יש לייבש אותו לפני השימוש."

msgid "Damp PVA is flexible and may get stuck in extruder. Dry it before use."
msgstr "PVA לח הוא גמיש ועלול להיתקע במכבש. יש לייבש אותו לפני השימוש."

msgid "PPS-CF is brittle and could break in bended PTFE tube above Toolhead."
msgstr "PPS-CF שביר ועלול להישבר בצינור PTFE הכפוף שמעל ראש ההדפסה."

msgid "PPA-CF is brittle and could break in bended PTFE tube above Toolhead."
msgstr "PPA-CF שביר ועלול להישבר בצינור PTFE הכפוף שמעל ראש ההדפסה."

msgid "PLA Glow may wear the AMS first stage feeder. Use an external spool instead."
msgstr "PLA Glow עלול לשחוק את מזין השלב הראשון של ה-AMS. יש להשתמש בסליל חיצוני במקום."

msgid "Default settings may affect print quality. Adjust as needed for best results."
msgstr "הגדרות ברירת מחדל עלולות להשפיע על איכות ההדפסה. יש להתאים לפי הצורך לתוצאות מיטביות."

#, possible-c-format, possible-boost-format
msgid "%s has a risk of nozzle clogging when using 0.4mm high-flow nozzles. Use with caution."
msgstr "ל-%s יש סיכון לסתימת זרבובית בעת שימוש בזרבוביות זרימה גבוהה של 0.4 מ\"מ. יש להשתמש בזהירות."

#, possible-c-format, possible-boost-format
msgid "%s filaments are hard and brittle and could break in AMS, and there is also a risk of nozzle clogging when using 0.4mm high-flow nozzles. Use with caution."
msgstr "פילמנטים מסוג %s קשים ושבירים ועלולים להישבר ב-AMS, וקיים גם סיכון לסתימת זרבובית בעת שימוש בזרבוביות זרימה גבוהה של 0.4 מ\"מ. יש להשתמש בזהירות."

#, possible-c-format, possible-boost-format
msgid "%s has a risk of nozzle clogging when using 0.4, 0.6, 0.8mm high-flow nozzles. Use with caution."
msgstr "ל-%s יש סיכון לסתימת זרבובית בעת שימוש בזרבוביות זרימה גבוהה של 0.4, 0.6, 0.8 מ\"מ. יש להשתמש בזהירות."

#, possible-c-format, possible-boost-format
msgid "%s is not supported by %s extruder."
msgstr "%s אינו נתמך על ידי מכבש %s."

msgid "The toolhead and hotend rack may move. Please keep your hands away from the chamber."
msgstr "ראש ההדפסה ומתקן ראשי החימום עלולים לנוע. יש להרחיק את הידיים מהתא."

msgid "Warning"
msgstr "אזהרה"

msgid "Hotend information may be inaccurate. Would you like to re-read the hotend? (Hotend information may change during power-off)."
msgstr "מידע ראש החימום עשוי להיות לא מדויק. האם ברצונך לקרוא מחדש את ראש החימום? (מידע ראש החימום עשוי להשתנות בזמן כיבוי)."

msgid "I confirm all"
msgstr "אני מאשר הכל"

msgid "Re-read all"
msgstr "קרא מחדש הכל"

msgid "Reading the hotends, please wait."
msgstr "קורא את ראשי החימום, אנא המתן."

msgid "During the hotend upgrade, the toolhead will move. Don't reach into the chamber."
msgstr "במהלך שדרוג ראש החימום, ראש ההדפסה ינוע. אין להכניס ידיים לתוך התא."

