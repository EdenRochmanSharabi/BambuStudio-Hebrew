msgstr "פתיחת zip שנכתב נכשלה"

msgid "Export successful"
msgstr "הייצוא הצליח"

#, possible-c-format, possible-boost-format
msgid ""
"The '%s' folder already exists in the current directory. Do you want to clear it and rebuild it.\n"
"If not, a time suffix will be added, and you can modify the name after creation."
msgstr ""
"התיקייה '%s' כבר קיימת בתיקייה הנוכחית. האם ברצונך לנקות אותה ולבנות אותה מחדש.\n"
"אם לא, יתווסף סיומת זמן, ותוכל לשנות את השם לאחר היצירה."

msgid ""
"Printer and all the filament&process presets that belong to the printer. \n"
"Can be shared with others."
msgstr ""
"מדפסת וכל הגדרות הפילמנט והתהליך הקבועות השייכות למדפסת. \n"
"ניתן לשתף עם אחרים."

msgid ""
"User's fillment preset set. \n"
"Can be shared with others."
msgstr ""
"ערכת הגדרות פילמנט קבועות של המשתמש. \n"
"ניתן לשתף עם אחרים."

msgid "Only display printer names with changes to printer, filament, and process presets."
msgstr "הצג רק שמות מדפסות עם שינויים בהגדרות קבועות של מדפסת, פילמנט ותהליך."

msgid "Only display the filament names with changes to filament presets."
msgstr "הצג רק שמות פילמנטים עם שינויים בהגדרות פילמנט קבועות."

msgid "Only printer names with user printer presets will be displayed, and each preset you choose will be exported as a zip."
msgstr "יוצגו רק שמות מדפסות עם הגדרות מדפסת קבועות של משתמש, וכל הגדרה קבועה שתבחר תיוצא כ-zip."

msgid ""
"Only the filament names with user filament presets will be displayed, \n"
"and all user filament presets in each filament name you select will be exported as a zip."
msgstr ""
"יוצגו רק שמות פילמנטים עם הגדרות פילמנט קבועות של משתמש, \n"
"וכל הגדרות הפילמנט הקבועות של המשתמש בכל שם פילמנט שתבחר ייוצאו כ-zip."

msgid ""
"Only printer names with changed process presets will be displayed, \n"
"and all user process presets in each printer name you select will be exported as a zip."
msgstr ""
"יוצגו רק שמות מדפסות עם הגדרות תהליך קבועות ששונו, \n"
"וכל הגדרות התהליך הקבועות של המשתמש בכל שם מדפסת שתבחר ייוצאו כ-zip."

msgid "Please select at least one printer or filament."
msgstr "אנא בחר לפחות מדפסת או פילמנט אחד."

msgid "Please select a type you want to export"
msgstr "אנא בחר סוג שברצונך לייצא"

msgid "Failed to create temporary folder, please try Export Configs again."
msgstr "יצירת תיקייה זמנית נכשלה, אנא נסה לייצא תצורות שוב."

msgid "Edit Filament"
msgstr "ערוך פילמנט"

msgid "Filament presets under this filament"
msgstr "הגדרות פילמנט קבועות תחת פילמנט זה"

msgid "Note: If the only preset under this filament is deleted, the filament will be deleted after exiting the dialog."
msgstr "הערה: אם ההגדרה הקבועה היחידה תחת פילמנט זה תימחק, הפילמנט יימחק לאחר יציאה מהדיאלוג."

msgid "Presets inherited by other presets can not be deleted"
msgstr "הגדרות קבועות שמורשות על ידי הגדרות קבועות אחרות לא ניתנות למחיקה"

msgid "The following presets inherits this preset."
msgid_plural "The following preset inherits this preset."
msgstr[0] "ההגדרה הקבועה הבאה יורשת הגדרה קבועה זו."
msgstr[1] "ההגדרות הקבועות הבאות יורשות הגדרה קבועה זו."

msgid "Delete Preset"
msgstr "מחק הגדרה קבועה"

msgid "Are you sure to delete the selected preset?"
msgstr "האם אתה בטוח שברצונך למחוק את ההגדרה הקבועה שנבחרה?"

msgid "Delete preset"
msgstr "מחק הגדרה קבועה"

